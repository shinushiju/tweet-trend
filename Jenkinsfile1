pipeline {
    agent {
        node {
            label 'maven'
        }
    }

    environment {
        PATH ="/opt/apache-maven-3.9.14/bin:$PATH"
    }

    stages {
        stage('build') {
            steps {
                sh 'mvn clean deploy'
                
            }
        }
    
        stage("Sonar Cube Analysis") {
            environment { 
                scannerHome = tool 'shinushiju-sonar-scanner'
            }
            steps{
            withSonarQubeEnv('shinushiju-sonarqube-server'){
                sh "${scannerHome}/bin/sonar-scanner"
            }    
            }

        }
           

    }

}
